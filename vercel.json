{
  "version": 2,
  "installCommand": "pnpm install --prod=false --no-frozen-lockfile --ignore-scripts",
  "buildCommand": "pnpm run build",
  "outputDirectory": "apps/web/dist",
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node",
      "config": { "includeFiles": "apps/api/src/**" }
    },
    {
      "src": "apps/web/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.ts",
      "methods": ["GET", "POST", "PUT", "DELETE", "PATCH"]
    },
    {
      "src": "/health",
      "dest": "/api/index.ts"
    },
    {
      "src": "^/assets/(.*)$",
      "dest": "/assets/$1",
      "headers": { "cache-control": "public, max-age=31536000, immutable" }
    },
    {
      "src": "^/(?!api|assets|health).*$",
      "dest": "/index.html"
    }
  ]
}
