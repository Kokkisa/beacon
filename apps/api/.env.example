# Amazon
AMAZON_CLIENT_ID=""
AMAZON_CLIENT_SECRET=""
AMAZON_REGION="us-east-1"

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Email (Resend)
RESEND_API_KEY=""
SENDER_EMAIL="noreply@beacon.so"

# Sentry
SENTRY_DSN=""

# Logging
LOG_LEVEL="info"
